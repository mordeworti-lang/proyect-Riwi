{
  "name": "clinical-management-system",
  "version": "1.0.0",
  "description": "Clinical Management System – Hybrid PostgreSQL + MongoDB API with Vanilla JS Frontend",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --forceExit",
    "migrate": "node scripts/run-migration.js",
    "migrate:clear": "node scripts/run-migration.js --clear",
    "seed": "node scripts/seed-data.js",
    "clean": "node scripts/clean-bad-data.js",
    "clean:keep-users": "node scripts/clean-bad-data.js --keep-users",
    "check-data": "node scripts/clean-bad-data.js --check",
    "setup": "npm run migrate && npm run seed",
    "reset": "npm run clean && npm run migrate && npm run seed"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.0.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "node-fetch": "^3.3.2",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "nodemon": "^3.1.7",
    "supertest": "^7.2.2"
  }
}
